import cv2
import numpy as np
import time

class MosquitoTracker:
    def __init__(self):
        # In a real build, replace with your custom YOLOv11-tiny model
        # self.model = YOLO('mosquito_detector.pt')
        
        # State: [x, y, vx, vy]
        self.state = np.array([0, 0, 0, 0], dtype=np.float32)
        self.dt = 0.01  # 10ms loop time
        
        # Kalman Filter transition matrix
        self.transition_matrix = np.array([
            [1, 0, self.dt, 0],
            [0, 1, 0, self.dt],
            [0, 0, 1, 0],
            [0, 0, 0, 1]
        ], dtype=np.float32)

    def predict_trajectory(self, current_pos, lead_time=0.02):
        """
        Predicts where the mosquito will be after 'lead_time' seconds.
        """
        x, y = current_pos
        
        # Update velocity (simplistic version)
        vx = (x - self.state[0]) / self.dt
        vy = (y - self.state[1]) / self.dt
        
        # Update state
        self.state = np.array([x, y, vx, vy])
        
        # Lead the target
        pred_x = x + (vx * lead_time)
        pred_y = y + (vy * lead_time)
        
        return int(pred_x), int(pred_y)

